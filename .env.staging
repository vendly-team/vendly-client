VITE_API_BASE_URL=https://stage-api.optoweek.uz

# Analytics — staging uses its own GTM container (never production GTM)
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENV=staging
VITE_GTM_CONTAINER_ID_STAGE=GTM-YYYYYYY
# VITE_GTM_CONTAINER_ID_PROD is intentionally not set in staging

# SEO — staging must never be indexed
VITE_SEO_INDEXING_ENABLED=false
VITE_PUBLIC_SITE_URL=https://stage.optoweek.uz
