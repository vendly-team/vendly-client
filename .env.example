# ═══════════════════════════════════════════════════════════════════════════════
# VENDLY FRONTEND — ENVIRONMENT VARIABLES
# Copy to .env.staging, .env.production, .env.development and fill in values.
# Never commit real secrets or IDs to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API ─────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://api-opto.vestor.uz

# ── Analytics ───────────────────────────────────────────────────────────────────
# Set to true to enable analytics. Always false for local development.
VITE_ANALYTICS_ENABLED=false

# Environment selector: local | staging | production
# - local    → analytics disabled regardless of VITE_ANALYTICS_ENABLED
# - staging  → loads VITE_GTM_CONTAINER_ID_STAGE only
# - production → loads VITE_GTM_CONTAINER_ID_PROD only
# ⚠ VITE_* vars are BAKED IN at build time. Wrong build mode = wrong analytics.
#   staging build must use: vite build --mode staging
#   production build must use: vite build  (or --mode production)
VITE_ANALYTICS_ENV=local

# GTM Container IDs — obtain from https://tagmanager.google.com after creating containers
# TODO: Create production GTM container → copy GTM-XXXXXXX here
# TODO: Create staging GTM container → copy GTM-YYYYYYY here
# TODO: Inside each GTM container, add GA4 Google Tag + Custom Event triggers for all 14 events
#       See docs/analytics-seo-cheatsheet.md § GTM Manual Setup for the full event list
VITE_GTM_CONTAINER_ID_PROD=GTM-XXXXXXX
VITE_GTM_CONTAINER_ID_STAGE=GTM-YYYYYYY

# ── SEO ─────────────────────────────────────────────────────────────────────────
# Set to true ONLY in production to allow public page indexing.
# Must be false for staging and local — staging must never be indexed.
VITE_SEO_INDEXING_ENABLED=false

# Canonical base URL — used for <link rel="canonical"> and Open Graph og:url
VITE_PUBLIC_SITE_URL=https://opto.vestor.uz
